# SignalStack Backend Environment Variables
# Copy this file to .env and fill in your values

# ==========================================
# REQUIRED SECRETS
# ==========================================

# GitHub Personal Access Token (for repo analysis)
# Create at: https://github.com/settings/tokens
# Required scopes: repo (read access)
GITHUB_TOKEN=your_github_token_here

# OpenAI API Key (for task decomposition and signal analysis)
# Required for core functionality. Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Optional: used only for internal estimated-cost metrics.
# Defaults are inferred for common OpenAI text models. Override if pricing changes.
# Example for gpt-5-mini standard pricing: input=$0.25/M, output=$2.00/M.
LLM_INPUT_COST_PER_1M=
LLM_OUTPUT_COST_PER_1M=

# ==========================================
# OPTIONAL - Database Configuration
# ==========================================

# Database URL (defaults to PostgreSQL for production)
# Format: postgresql://user:password@host/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/signalstack

# Optional: Dedicated test database (used by pytest integration tests)
DATABASE_URL_TEST=postgresql://postgres:password@localhost:5432/signalstack_test

# ==========================================
# OPTIONAL - Redis Configuration
# ==========================================

# Redis URL for caching (falls back to in-memory if not available)
# Format: redis://[[username]:[password]@]host[:port][/database]
REDIS_URL=redis://localhost:6379/0

# ==========================================
# OPTIONAL - Security Configuration
# ==========================================

# JWT Secret for token signing (change in production!)
AUTH_SECRET=replace-with-a-long-random-secret
JWT_SECRET=

# Email that receives admin-only access to Admin, System Learning, logs, and JSON metrics.
ADMIN_EMAIL=you@example.com

# Optional demo recruiter seed credentials used by backend/seed_demo_auth.py
DEMO_RECRUITER_EMAIL=demo@signalstack.dev
DEMO_RECRUITER_PASSWORD=Demo@12345

# API Key for external plugin authentication
SIGNALSTACK_API_KEY=

# ==========================================
# OPTIONAL - Worker Configuration
# ==========================================

# Number of background worker threads
WORKER_THREADS=3

# ==========================================
# OPTIONAL - Feature Flags
# ==========================================

# Enable debug mode (verbose logging)
DEBUG=false

# Enable LLM summarization (set to false to use deterministic only)
ENABLE_LLM_SUMMARIZATION=true

# Public base URL for job pages (used in SEO-friendly links)
PUBLIC_BASE_URL=http://localhost:3000

