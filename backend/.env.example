# SignalStack Backend Environment Variables
# Copy this file to .env and fill in your values

# ==========================================
# REQUIRED SECRETS
# ==========================================

# GitHub Personal Access Token (for repo analysis)
# Create at: https://github.com/settings/tokens
# Required scopes: repo (read access)
GITHUB_TOKEN=your_github_token_here

# ==========================================
# OPTIONAL - LLM Configuration
# ==========================================

# Google Gemini API Key (for AI features)
# Get it from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# OPTIONAL - Database Configuration
# ==========================================

# Database URL (defaults to SQLite if not set)
# For PostgreSQL: postgresql://user:password@localhost:5432/signalstack
DATABASE_URL=sqlite:///./signalstack.db

# ==========================================
# OPTIONAL - Redis Configuration
# ==========================================

# Redis URL for caching (falls back to in-memory if not available)
# Format: redis://[[username]:[password]@]host[:port][/database]
REDIS_URL=redis://localhost:6379/0

# ==========================================
# OPTIONAL - Security Configuration
# ==========================================

# JWT Secret for token signing (change in production!)
JWT_SECRET=dev-secret-change-in-production-abc123

# API Key for external plugin authentication
SIGNALSTACK_API_KEY=

# ==========================================
# OPTIONAL - Worker Configuration
# ==========================================

# Number of background worker threads
WORKER_THREADS=3

# ==========================================
# OPTIONAL - Feature Flags
# ==========================================

# Enable debug mode (verbose logging)
DEBUG=false

# Enable LLM summarization (set to false to use deterministic only)
ENABLE_LLM_SUMMARIZATION=true

